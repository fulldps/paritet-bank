# === SERVER ===
PORT=3000

# === DATABASE ===
# При запуске через Docker DB_HOST переопределяется в docker-compose.yml на "postgres"
# При локальном запуске без Docker — оставь localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=paritet
DB_PASSWORD=paritet_secret
DB_NAME=paritet_bank

# === CORS ===
# URL фронтенда — нужен для CORS (если фронт на другом домене/порту)
# При Docker-запуске: http://localhost (порт 80)
# При dev-запуске: http://localhost:5173
FRONTEND_URL=http://localhost

# === GROQ AI ===
# Получи бесплатно: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
