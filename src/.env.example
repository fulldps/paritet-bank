# === FRONTEND ===
# URL бэкенда — используется в AppChatBot.vue и AppCurrencyConverter.vue
#
# При запуске через Docker (production): http://localhost:3000/api
# При dev-запуске локально:              http://localhost:3000/api
# При деплое на сервер (другой IP):      http://<IP_СЕРВЕРА>:3000/api
#
# Если не задано — код сам использует fallback: http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
